menu "Shell"

config HOMECORE_SHELL
    bool "Enable shell subsystem"
    default y

if HOMECORE_SHELL

config HOMECORE_SHELL_PROMPT
    string "Shell prompt"
    default "$ "

config HOMECORE_SHELL_MAX_INPUT_LENGTH
    int "Maximum shell input length"
    default 128 

config HOMECORE_SHELL_MAX_ARGS
    int "Maximum number of arguments for shell commands"
    default 10
    range 1 20

endif

endmenu